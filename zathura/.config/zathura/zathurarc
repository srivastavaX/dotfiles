# Window / Layout
set window-height 3000
set window-width 3000
set window-title-basename "true"

# Font
set font "Inconsolata 9"

# Clipboard
set selection-clipboard clipboard

# Scrolling (smoother)
set scroll-page-aware "true"
set smooth-scroll "true"
set scroll-full-overlap 0.08
set scroll-step 80

# Dark theme
set default-bg "#0A0A0A"
set default-fg "#EAEAEA"

set statusbar-bg "#121212"
set statusbar-fg "#AFAFAF"

set inputbar-bg "#101010"
set inputbar-fg "#FFFFFF"

set completion-bg "#1A1A1A"
set completion-fg "#D0D0D0"
set completion-highlight-bg "#4C9AFF"
set completion-highlight-fg "#0A0A0A"

set notification-bg "#2E7D32"
set notification-fg "#FFFFFF"

set notification-warning-bg "#FFB300"
set notification-warning-fg "#000000"

set notification-error-bg "#D32F2F"
set notification-error-fg "#FFFFFF"

# Highlighting
set highlight-color '#FFD166'
set highlight-active-color '#4C9AFF'

# Rendering
set render-loading "false"
set render-loading-bg "#0A0A0A"

# Recolor Mode
set recolor "false"
set recolor-lightcolor "#000000"
set recolor-darkcolor "#EAEAEA"
set recolor-reverse-video "true"
set recolor-keephue "true"

# UX improvements
set adjust-open "best-fit"
set statusbar-home-tilde "true"
set window-icon "true"

# Search Behavior
set incremental-search "true"
set search-wrap "true"

# Vim-style
map j scroll down
map k scroll up
map h scroll left
map l scroll right
map J navigate next
map K navigate previous
map <C-d> scroll half-down
map <C-u> scroll half-up
map <C-f> scroll full-down
map <C-b> scroll full-up
map <Space> scroll full-down
map <C-Space> scroll full-up

map r rotate
map R rotate-ccw

map q quit
map s save

map y copy-to-clipboard

map d recolor

# modes = alternate тАЬlayersтАЭ of keybindings
# When you switch into that mode, the default key bindings are suspended 
# and replaced by the bindings defined in that mode. 

# PASSTHROUGH MODE
# for virtual machine and stuff: so that i3 keybindings won't intercept keystrokes which are meant for the guest OS
set $mode_passthrough "Passthrough [Press Mod4+F12 to exit.]"
bindsym $mod+F12 mode $mode_passthrough
mode $mode_passthrough {
    bindsym $mod+F12 mode "default"
}

# POWER MODE
set $power_mode "(l)ock | (e)xit | (s)uspend | (r)eboot | (p)oweroff"
bindsym $mod+Escape mode $power_mode
mode $power_mode {
    bindsym l exec --no-startup-id $SCRIPTS/lock, mode "default"
    bindsym e exec --no-startup-id i3-msg exit, mode "default"
    bindsym s exec --no-startup-id systemctl suspend, mode "default"
    bindsym r exec --no-startup-id systemctl reboot, mode "default"
    bindsym p exec --no-startup-id systemctl poweroff, mode "default"

    bindsym Escape mode "default"
    bindsym Return mode "default"
}

# RESIZE MODE (supports mouse)
set $resize_mode "Resize: (i)grow-W | (o)shrink-W | (9)grow-H | (0)shrink-H"
bindsym $mod+r mode $resize_mode
mode $resize_mode {
    bindsym o       resize shrink   width   10 px   or 10 ppt
    bindsym i       resize grow     width   10 px   or 10 ppt
    bindsym 0       resize shrink   height  10 px   or 10 ppt
    bindsym 9       resize grow     height  10 px   or 10 ppt

    bindsym Shift+o resize shrink   width   4 px    or 4 ppt
    bindsym Shift+i resize grow     width   4 px    or 4 ppt
    bindsym Shift+0 resize shrink   height  4 px    or 4 ppt
    bindsym Shift+9 resize grow     height  4 px    or 4 ppt

    bindsym 1       floating enable, resize set 30ppt 30ppt,    move position center
    bindsym 2       floating enable, resize set 50ppt 50ppt,    move position center
    bindsym 3       floating enable, resize set 60 ppt 70 ppt,  move position center
    bindsym 4       floating enable, resize set 25 ppt 90 ppt,  move position center

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

# GAPS MODE
set $defaultInnerGaps 0
set $defaultOuterGaps 0

# Apply defaults on startup
gaps inner $defaultInnerGaps
gaps outer $defaultOuterGaps

set $gapsMode "gaps: inner(i|o), outer(Shift+i|o), (z)en"
bindsym $mod+g mode $gapsMode
mode $gapsMode {
    bindsym i               gaps inner current plus 5
    bindsym o               gaps inner current minus 5
    bindsym Shift+i         gaps outer current plus 5
    bindsym Shift+o         gaps outer current minus 5

    # Current workspace resets
    bindsym 0               mode "default", gaps inner current set 0, gaps outer current set 0
    bindsym d               mode "default", gaps inner current set $defaultInnerGaps, gaps outer current set $defaultOuterGaps

    # Global workspace resets
    bindsym Shift+0         mode "default", gaps inner all set 0, gaps outer all set 0
    bindsym Shift+d         mode "default", gaps inner all set $defaultInnerGaps, gaps outer all set $defaultOuterGaps

    # Zen mode
    bindsym z               mode "default", gaps inner current set 10, gaps outer current set 70

    bindsym Return          mode "default"
    bindsym Escape          mode "default"
}



alias x=' startx'
alias v=' $EDITOR'
alias vim=' nvim'
alias sv='sudoedit'

alias incog=' unset HISTFILE'

# ls
alias ls='ls -h --color=always'  # keep it sane: avoids insanity when piping
alias l='eza -l --git --icons --group-directories-first --sort=name --color=always'
alias la='eza -a --git --icons --group-directories-first --sort=name'
alias ll='eza -lah@ --all --icons --git --group-directories-first --sort=name --color=always'
alias ld='eza -D --icons --sort=name' 
alias lf='eza -f --icons --sort=name'
alias lt='eza --tree --level=2 --long --git --icons --group-directories-first'
alias ltt='eza --tree --long --git --icons --group-directories-first'

alias lm='eza -l --git --icons --sort=modified --reverse --color=always'  # modified time
alias lz='eza -l --git --icons --sort=size --reverse --color=always'  # size

# eza uses nerd-fonts

# DIRECTORIES
alias dots=' cd $DOTFILES && ls'

# config-files
alias vzrc=' v ~/.zshrc'
alias szrc=' source ~/.zshrc'
alias vi3=' v ~/.config/i3/config'

#alias sk='killall ssh-agent && source ~/.zshrc'

alias ..=' cd .. && ll'
alias ...=' cd ../.. && ll'
alias c=' clear'
alias q=' exit'
alias hist=' history -i'
alias cd=' cd'
alias shut=' shutdown now'
alias sus=' systemctl suspend'

#alias cm='cmake ..'
#alias mk='make -j$(nproc)'
#alias ut='tar xf'

alias bat='bat --paging=never --style=grid,numbers,changes --color=always'

# : trash-list
# : trash-restore
# : trash-empty
# : trash-empty 30  # delete files trashed more than 30 days ago
# .local/share/Trash
alias rt='trash-put --verbose'
alias rm='rm -i'

alias mv='mv -i'

# scripts
alias Rd=' eval "$($SCRIPTS/1-cd)"'
alias Rs=' eval "$($SCRIPTS/exec-script)"'


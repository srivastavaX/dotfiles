[global]
# Display
follow = mouse
width = 460
height = (0, 400)
origin = top-center
offset = (20, 20)
indicate_hidden = yes
notification_limit = 5
gap_size = 12
separator_height = 2
padding = 10
horizontal_padding = 18
text_icon_padding = 14
frame_width = 3
sort = yes

# Progress bar
progress_bar = true
progress_bar_corner_radius = 6
progress_bar_frame_width = 0
progress_bar_min_width = 120
progress_bar_max_width = 300
progress_bar_height = 10

# Colors
foreground = "#091413"
background = "#cbf3bb"
frame_color = "#89FC00"

highlight = "#2563eb"

# Text
font = JetBrainsMono Nerd Font 10
markup = full
format = "<span size='medium'> <span foreground='#6c7086'>%a</span></span>\n<span weight='bold' foreground='#000000' size='large'>%s</span>\n<span>%b</span>"
alignment = left
vertical_alignment = center

# Icon
icon_theme = Adwaita
enable_recursive_icon_lookup = true
icon_position = left
min_icon_size = 48
max_icon_size = 64
icon_corner_radius = 8

# Misc/Advanced
title = "Notification"
history_length = 50
dmenu = rofi -dmenu -p "Notification"
corner_radius = 0

# Mouse
mouse_left_click = do_action, close_current
mouse_middle_click = close_current
mouse_right_click = close_all

[urgency_normal]
foreground = "#091413"
background = "#CDDDDD"
frame_color = "#009DDC"
highlight = "#3b82f6"
timeout = 6

[urgency_low]
background = "#eef2f7"
foreground = "#374151"
frame_color = "#A599B5"
timeout = 3

[urgency_critical]
background = "#fff1f2"
foreground = "#7f1d1d"
frame_color = "#cf203e"
highlight = "#ef4444"
timeout = 0

# Rules
[fullscreen_delay_everything]
fullscreen = delay

[fullscreen_show_critical]
msg_urgency = critical
fullscreen = show

[global]
# Display
follow = mouse
width = 500
height = (0, 400)
origin = top-center
offset = (20, 20)
indicate_hidden = yes
notification_limit = 5
gap_size = 10
separator_height = 2
padding = 8
horizontal_padding = 20
text_icon_padding = 14
frame_width = 2
sort = yes

# Progress bar
progress_bar = true
progress_bar_corner_radius = 6
progress_bar_frame_width = 0
progress_bar_min_width = 120
progress_bar_max_width = 300
progress_bar_height = 10

# Colors
#foreground = "#e5e9f0"
#frame_color = "#4c566a"
#background = "#1e222aee"
#highlight = "#88c0d0, #5e81ac"
background = "#282828ee"
foreground = "#ebdbb2"
frame_color = "#d79921"
highlight = "#fabd2f"
separator_color = frame

# Text
font = JetBrainsMono Nerd Font 10
markup = full
#format = "<small>%a</small>\n<b>%s</b>\n%b"
format = "<span size='small'>  <span foreground='#6c7086'>%a</span></span>\n<span weight='bold' size='large'>%s</span>\n<span foreground='#a6adc8'>%b</span>"
#format = "<b>%s</b>\n<span size='smaller' foreground='#89b4fa'>%a</span>\n%b"
alignment = left
vertical_alignment = center
#show_age_threshold = -1
#hide_duplicate_count = false

# Icon
icon_theme = Adwaita
enable_recursive_icon_lookup = true
icon_position = left
min_icon_size = 48
max_icon_size = 64
icon_corner_radius = 8
#icon_path = /usr/share/icons/Adwaita/scalable/status:/usr/share/icons/Adwaita/symbolic/status
#icon_path = /usr/share/icons/hicolor/scalable/apps

# Misc/Advanced
title = "Notification"
history_length = 50
dmenu = rofi -dmenu -p "Notification"
corner_radius = 10

# Mouse
mouse_left_click = do_action, context
mouse_middle_click = do_action, close_current
mouse_right_click = close_current

[urgency_normal]
background = "#1e1e2edd"
foreground = "#cdd6f4"
frame_color = "#89b4fa"
highlight = "#89b4fa"
timeout = 6

[urgency_low]
background = "#181825dd"
foreground = "#a6adc8"
frame_color = "#6c7086"
highlight = "#6c7086"
timeout = 3

[urgency_critical]
background = "#302d41ee"
foreground = "#f38ba8"
frame_color = "#f38ba8"
highlight = "#fab387"
timeout = 0

# Rules
[fullscreen_delay_everything]
fullscreen = delay

[fullscreen_show_critical]
msg_urgency = critical
fullscreen = show
